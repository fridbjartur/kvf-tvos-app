{
  "expo": {
    "name": "Tomo TV",
    "slug": "tomotv",
    "description": "Stream any video from your Jellyfin server. Automatic transcoding handles incompatible formats so you can just hit play and watch.",
    "version": "1.4.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "tomotv",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#1C1C1E",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.keiver.tomotv",
      "buildNumber": "1",
      "version": "1.4.0",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSLocalNetworkUsageDescription": "Tomo TV needs to access your local network to connect to your Jellyfin media server and stream videos to your Apple TV.",
        "NSBonjourServices": ["_jellyfin._tcp"]
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/input-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F39C12",
          "dark": {
            "backgroundColor": "#1C1C1E"
          }
        }
      ],
      [
        "@react-native-tvos/config-tv",
        {
          "isTV": true,
          "tvosDeploymentTarget": "16.4"
        }
      ],
      "expo-secure-store",
      "./plugins/withMultiAudioResourceLoader",
      "./plugins/withTVImageAssets",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "android": {
      "package": "dev.keiver.tomotv"
    }
  }
}
