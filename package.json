{
  "name": "tomotv",
  "version": "1.5.0",
  "description": "Stream videos from your Jellyfin server on Apple TV with automatic transcoding",
  "main": "expo-router/entry",
  "author": "Keiver Hernandez <contact@keiver.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/keiver/tomotv.git"
  },
  "bugs": {
    "url": "https://github.com/keiver/tomotv/issues"
  },
  "homepage": "https://keiver.dev/lab/tomotv",
  "keywords": [
    "jellyfin",
    "tvos",
    "apple-tv",
    "react-native",
    "video-player",
    "streaming",
    "expo",
    "transcoding",
    "mkv",
    "media-server",
    "media-center",
    "home-theater"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx expo lint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prebuild:tv": "EXPO_TV=1 expo prebuild --clean",
    "prebuild": "expo prebuild --clean",
    "lib": "npm uninstall expo-tvos-search && npm cache clean --force && npm install expo-tvos-search@github:keiver/expo-tvos-search#tint-fix && rm -rf .expo .metro-cache && yes | EXPO_TV=1 npx expo prebuild --clean && npx expo start --clear",
    "clear": "rm -rf .expo .metro-cache node_modules package-lock.json && npm i && yes | EXPO_TV=1 npx expo prebuild --clean && npx expo start --clear",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "@expo/vector-icons": "^15.0.2",
    "expo": "^56.0.0",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.18",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-image": "~56.0.11",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-modules-core": "~56.0.17",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-tvos-search": "~2.0.0",
    "react": "19.2.3",
    "react-native": "npm:react-native-tvos@0.85.0-0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-video": "^6.19.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-tvos/config-tv": "^0.1.4",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "^56.0.0",
    "lint-staged": "^16.3.2",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.6.2",
    "react-test-renderer": "19.2.3",
    "ts-jest": "^29.4.5",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native",
        "typescript"
      ]
    }
  },
  "overrides": {
    "react-dom": "19.2.3",
    "react-native": "$react-native"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "private": true
}
